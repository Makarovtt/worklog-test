{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "setupFiles": ["<rootDir>/test/setup-env.ts"],
  "globalSetup": "<rootDir>/test/global-setup.ts"
}
